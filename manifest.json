{
  "manifest_version": 3,
  "name": "Verbatim Interlinear Translator",
  "version": "0.4.0",
  "description": "Word-by-word interlinear translation injected into page HTML.",
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "minimum_chrome_version": "88",
  "permissions": ["storage", "activeTab", "tabs", "contextMenus", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Verbatim Interlinear — toggle whole-page translation",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png"
    }
  },
  "commands": {
    "toggle-page-translation": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Toggle whole-page interlinear translation"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ]
}
