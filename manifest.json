{
  "manifest_version": 3,
  "name": "Verbatim Interlinear Translator",
  "version": "0.3.0",
  "description": "Word-by-word interlinear translation injected into page HTML.",
  "permissions": ["storage", "activeTab", "tabs", "contextMenus"],
  "host_permissions": ["https://api-free.deepl.com/*", "https://api.deepl.com/*", "https://translation.googleapis.com/*", "https://*.googleapis.com/*", "https://api.cognitive.microsofttranslator.com/*", "http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Verbatim Interlinear — toggle whole-page translation",
    "default_popup": "popup/popup.html"
  },
  "commands": {
    "toggle-page-translation": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Toggle whole-page interlinear translation"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ]
}
